## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Visual Studio cache
.vs/
.vscode/

# Rider / JetBrains
.idea/
*.sln.iml

# MSBuild
*.log
*.tlog
*.binlog

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# Dotnet tools
.dotnet/
*.dll
*.exe
*.pdb
*.mdb

# Assemblies & compiled output
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp_proj
*_wpftmp.csproj

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# ASP.NET Core
appsettings.Development.json
appsettings.Local.json
appsettings.*.json

# Config files
*.config
!App.config
launchSettings.json

# IIS / Express
.vs/config/
*.applicationhost.config

# Publish
publish/
wwwroot/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Backup & temp
*.bak
*.tmp
*.temp
*.swp
*~

